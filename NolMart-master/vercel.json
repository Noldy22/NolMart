{
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "scripts": {
    "build": "node scripts/build-products.js"
  },
  "cleanUrls": true,
  "trailingSlash": false
}